{
  "manifest_version": 3,
  "name": "PageMind — AI Page Assistant",
  "version": "2.0",
  "description": "Liquid-glass AI assistant that reads pages, searches the web, and answers your questions.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://html.duckduckgo.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PageMind Settings"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}